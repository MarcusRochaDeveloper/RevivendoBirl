{
  "name": "birl-vscode-extension",
  "displayName": "BIRL Language Support",
  "description": "Syntax highlighting e execução para a linguagem BIRL 💪",
  "version": "1.0.0",
  "publisher": "marcus-e-adam",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MarcusRochaDeveloper/RevivendoBirl"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "birl",
    "bambam",
    "esoteric",
    "language"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "birl",
        "aliases": [
          "BIRL",
          "birl"
        ],
        "extensions": [
          ".birl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "birl",
        "scopeName": "source.birl",
        "path": "./syntaxes/birl.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "birl.run",
        "title": "BIRL: Executar Treino 💪",
        "category": "BIRL"
      }
    ],
    "keybindings": [
      {
        "command": "birl.run",
        "key": "ctrl+alt+b",
        "mac": "cmd+alt+b",
        "when": "editorLangId == birl"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "birl.run",
          "when": "editorLangId == birl",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "echo 'HORA DO SHOW!'",
    "package": "vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.0"
  }
}
